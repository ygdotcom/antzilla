# === FACTORY — THIS IS ALL YOU NEED IN .env ===
#
# All API keys are managed via the CEO Dashboard → Settings page.
# They are encrypted with AES-256-GCM and stored in Postgres.
# You never need to edit this file after initial setup.

# Database (Docker Compose needs this to boot)
POSTGRES_PASSWORD=changeme_use_a_real_password

# Encryption (protects API keys stored in DB)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=changeme_generate_with_openssl_rand_hex_32

# CEO Dashboard auth
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=changeme_use_a_real_password

# Daily budget cap (USD)
DAILY_BUDGET_LIMIT_USD=50.00
AGENT_DEFAULT_DAILY_LIMIT_USD=5.00
