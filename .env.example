# ═══ DATABASE ═══
POSTGRES_PASSWORD=changeme_use_a_real_password
DATABASE_URL=postgresql+asyncpg://factory:changeme_use_a_real_password@localhost:5432/factory

# ═══ HATCHET ═══
# Token is auto-generated by hatchet-setup on first docker compose up.
# The factory-worker reads it from the mounted /hatchet/config/.env file.
# For external workers, generate one via:
#   docker compose run --no-deps hatchet-setup /hatchet/hatchet-admin token create \
#     --config /hatchet/config --tenant-id 707d0855-80ab-4e1f-a156-f1c4546cbf52
HATCHET_CLIENT_TOKEN=
HATCHET_CLIENT_TLS_STRATEGY=none

# ═══ ANTHROPIC (Claude) ═══
ANTHROPIC_API_KEY=sk-ant-...

# ═══ STRIPE ═══
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ═══ DOMAIN & INFRA ═══
NAMECHEAP_API_KEY=
NAMECHEAP_API_USER=
CLOUDFLARE_API_TOKEN=
VERCEL_TOKEN=
GITHUB_TOKEN=ghp_...

# ═══ SUPABASE (for per-business DBs) ═══
SUPABASE_ACCESS_TOKEN=

# ═══ EMAIL ═══
SENDGRID_API_KEY=SG....
INSTANTLY_API_KEY=
RESEND_API_KEY=re_...

# ═══ ADVERTISING ═══
GOOGLE_ADS_DEVELOPER_TOKEN=
META_ADS_ACCESS_TOKEN=

# ═══ SOCIAL ═══
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# ═══ VOICE / TELEPHONY ═══
RETELL_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ═══ LEAD ENRICHMENT ═══
APOLLO_API_KEY=
HUNTER_API_KEY=
DROPCONTACT_API_KEY=
ZEROBOUNCE_API_KEY=
SPARKTORO_API_KEY=
SERPER_API_KEY=

# ═══ NOTIFICATIONS ═══
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# ═══ ANALYTICS ═══
PLAUSIBLE_BASE_URL=http://localhost:8000
PLAUSIBLE_SECRET=changeme_generate_with_openssl_rand_base64_64

# ═══ DASHBOARD ═══
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=changeme_use_a_real_password

# ═══ BUDGET LIMITS (USD) ═══
DAILY_BUDGET_LIMIT_USD=50.00
AGENT_DEFAULT_DAILY_LIMIT_USD=5.00
