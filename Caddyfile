# CEO Dashboard — hub.antzilla.ca with auto Let's Encrypt
hub.antzilla.ca {
	reverse_proxy dashboard:9000
}

# Also serve on IP (self-signed for direct IP access)
https://:443 {
	tls internal {
		on_demand
	}
	reverse_proxy dashboard:9000
}

# Hatchet Dashboard — HTTPS on :8443
https://:8443 {
	tls internal {
		on_demand
	}
	reverse_proxy hatchet-dashboard:80
}

# Plausible Analytics — HTTPS on :8444
https://:8444 {
	tls internal {
		on_demand
	}
	reverse_proxy plausible:8000
}

# Uptime Kuma — HTTPS on :3002
https://:3002 {
	tls internal {
		on_demand
	}
	reverse_proxy uptime-kuma:3001
}

# HTTP → HTTPS redirect
http://:80 {
	redir https://{host}{uri} permanent
}
